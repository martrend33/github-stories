
{

  "name": "GitHub Chat",
    "version": "0.2.0",
    "description": "Open GitHub Chat from any GitHub page.",
    "manifest_version": 3,
    "permissions": [
          "storage"
    ],
    "host_permissions": [
          "https://github.com/*"
    ],
    "content_scripts": [
          {
                  "matches": [
                            "https://github.com/*"
                  ],
                  "js": [
                            "content-script.js"
                  ],
                  "css": [
                            "github-chat.css"
                  ],
                  "run_at": "document_idle"
          }
    ],
    "options_ui": {
          "page": "options.html",
          "open_in_tab": false
    }
}
